# ================================
# DJANGO / APLICACION
# ================================
# Modo debug (False en produccion)
DEBUG=False

# Clave secreta de Django
SECRET_KEY=changeme

# ================================
# BASE DE DATOS (POSTGRESQL)
# ================================
# Motor de base de datos usado por Django
DB_ENGINE=django.db.backends.postgresql

# Conexion principal a PostgreSQL
DB_NAME=tiendadb
DB_USER=admin_motos
DB_PASSWORD=changeme
DB_HOST=localhost
DB_PORT=5432

# ================================
# CORREO / SMTP
# ================================
# Backend personalizado para forzar HELO valido
EMAIL_BACKEND=config.email_backend.EmailBackend

# Servidor SMTP y puerto
EMAIL_HOST=srv65.benzahosting.cl
EMAIL_PORT=465

# Credenciales de la cuenta SMTP
EMAIL_HOST_USER=contacto@delanoemotos.cl
EMAIL_HOST_PASSWORD=changeme

# Seguridad SMTP (puerto 465 => SSL=True, TLS=False)
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False

# Timeout de envio (en segundos)
EMAIL_TIMEOUT=20

# Hostname enviado en HELO/EHLO
EMAIL_HELO_NAME=delanoemotos.cl

# Remitente por defecto de los correos
DEFAULT_FROM_EMAIL=Delanoe Motos <contacto@delanoemotos.cl>

# ================================
# DATOS DE EMPRESA (PLANTILLAS EMAIL)
# ================================
COMPANY_NAME=Delanoe Motos
COMPANY_SUPPORT_EMAIL=soporte@delanoemotos.cl
COMPANY_SUPPORT_PHONE=+56 9 0000 0000
